
{
	"layer": "top",
//	"height": "30",
    "modules-left": ["custom/menu", "wlr/workspaces", "user" ],
    "modules-center": [ "hyprland/window"],
    "modules-right": ["pulseaudio", "network", "cpu", "memory","keyboard-state","clock", "tray", "custom/power"],

    "wlr/workspaces": {
 //       "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}: {icon}",
        "format-icons": {
            "1": "ΎΕι",
            "2": "ΎΚρ",
            "3": "ΎΕκ",
            "4": "ΎΗ╝",
            "5": "ΎΒ╡",
            "urgent": "ΎΒς",
            "focused": "ΎΗΤ",
            "default": "ΎΕΣ"
        },
        "sort-by-number": true,
   },

   "keyboard-state": {
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "ΎΑμ",
            "unlocked": "ΎΓε"
        }
    },

    "clock": {
        "timezone": "Africa/Maputo",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>",
        "format-alt": "{:%d-%m-%Y}"
    },

    "cpu": {
        "format": "{usage}% ΎΜδ",
        "tooltip": false
    },

    "memory": {
        "format": "{}% ΎΔΚ "
    },

    "pulseaudio": {
        
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "Ύγσ {format_source}",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },

	"hyprland/window": {
		"format" : "ΌεΠ {}",
		"separate-outputs" : true,
		"max-length": 40
	},

	"custom/menu" : {
		"format": " ΎΝΔ ",
		"tooltip" : false,
		"on-click": " ~/.config/waybar/scripts/menu.sh",
	},

	"custom/power": {
		"format": "ΎΑΣ  ",
		"tooltip": false,
		"on-click": "$HOME/.config/waybar/scripts/session_manager.sh",
	},

	"user": {
        "format": "Όχβ {user} (up {work_H}:{work_M}:{work_S} έΗΣ)",
        "interval": 1,
        "height": 30,
        "width": 30,
        "icon": true,
},

}
